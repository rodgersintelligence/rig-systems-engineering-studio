# RIG lattice viewer — environment variables
# Copy to .env.local and fill in values for local dev.

# SSE event stream base URL (port 8765 is the default rig.runtime server).
# The viewer subscribes to ${VITE_RIG_EVENT_URL}/events/stream.
# Override at runtime via ?events=http://host:port query param.
VITE_RIG_EVENT_URL=http://localhost:8765

# Private runtime server base URL for memory recall, health, and phronema endpoints.
# Exposes: /memory/recall  /memory/status  /rgi/health  /phronema/proactive/status
# Default port is 8780. Override at runtime via ?runtime=http://host:port query param.
VITE_RIG_RUNTIME_URL=http://localhost:8780

# Set to "false" to disable the MemoryHoverPanel and RGI status tile entirely.
# Useful when the private runtime server is not running locally.
VITE_RIG_MEMORY_ENABLED=true

# Injected automatically by the CI deploy workflow; do not set manually.
# VITE_BUILD_ID=<git-sha>
